# EMAIL PROVIDER CONFIGURATION
# Copy this file to .env and fill in your credentials for local development
# For production, set these as environment variables in Railway

# ==================== SENDGRID API ====================
PROVIDER_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
PROVIDER_SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ==================== RESEND API ====================
PROVIDER_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
PROVIDER_RESEND_FROM_EMAIL=noreply@yourdomain.com

# ==================== POSTMARK API ====================
PROVIDER_POSTMARK_API_KEY=xxxxxxxxxxxxxxxxxxxxx
PROVIDER_POSTMARK_FROM_EMAIL=noreply@yourdomain.com

# ==================== BREVO API ====================
PROVIDER_BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxx
PROVIDER_BREVO_FROM_EMAIL=noreply@yourdomain.com

# ==================== MAILGUN API ====================
PROVIDER_MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxx
PROVIDER_MAILGUN_DOMAIN=mail.yourdomain.com
PROVIDER_MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# ==================== DATABASE (Supabase) ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ==================== CELERY / REDIS ====================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==================== FRONTEND ====================
NEXT_PUBLIC_API_URL=http://localhost:8080

# Instructions:
# 1. Get SendGrid API key from: https://app.sendgrid.com/settings/api_keys
# 2. Get Resend API key from: https://resend.com/api-keys
# 3. Get Postmark API key from: https://account.postmarkapp.com/servers
# 4. Get Brevo API key from: https://app.brevo.com/settings/keys/api
# 5. Get Mailgun API key from: https://app.mailgun.com/app/account/security/api_keys
# You don't need all providers - just set the ones you're using!
